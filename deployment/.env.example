# VoiceHelpDeskAI Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# GENERAL CONFIGURATION
# =============================================================================

# Environment
VOICEHELPDESK_ENV=production
VOICEHELPDESK_DEBUG=false
VOICEHELPDESK_LOG_LEVEL=INFO

# Security
VOICEHELPDESK_SECRET_KEY=your-super-secret-key-change-this-in-production
VOICEHELPDESK_CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# API Settings
VOICEHELPDESK_API_HOST=0.0.0.0
VOICEHELPDESK_API_PORT=8000
VOICEHELPDESK_API_WORKERS=4
VOICEHELPDESK_API_TIMEOUT=300

# Database
VOICEHELPDESK_DATABASE_URL=sqlite:///app/data/voicehelpdesk.db
# For PostgreSQL: postgresql://user:password@postgres:5432/voicehelpdesk

# Redis
VOICEHELPDESK_REDIS_URL=redis://redis:6379/0

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================

# Model Paths
VOICEHELPDESK_MODEL_PATH=/app/models

# Speech-to-Text (Whisper)
VOICEHELPDESK_WHISPER_MODEL=base
VOICEHELPDESK_WHISPER_DEVICE=cpu
VOICEHELPDESK_WHISPER_COMPUTE_TYPE=int8

# Text-to-Speech (Piper)
VOICEHELPDESK_PIPER_MODEL=en_US-amy-medium
VOICEHELPDESK_PIPER_QUALITY=medium

# Language Model
VOICEHELPDESK_LLM_PROVIDER=openai
VOICEHELPDESK_LLM_MODEL=gpt-3.5-turbo
VOICEHELPDESK_LLM_MAX_TOKENS=1000
VOICEHELPDESK_LLM_TEMPERATURE=0.7

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ORG_ID=your-org-id-here

# =============================================================================
# AUDIO PROCESSING
# =============================================================================

# Audio Settings
VOICEHELPDESK_AUDIO_SAMPLE_RATE=16000
VOICEHELPDESK_AUDIO_CHANNELS=1
VOICEHELPDESK_AUDIO_CHUNK_SIZE=1024

# Voice Activity Detection
VOICEHELPDESK_VAD_ENABLED=true
VOICEHELPDESK_VAD_AGGRESSIVENESS=2
VOICEHELPDESK_VAD_FRAME_DURATION=30

# Audio Processing
VOICEHELPDESK_NOISE_REDUCTION=true
VOICEHELPDESK_AUDIO_ENHANCEMENT=true
VOICEHELPDESK_ECHO_CANCELLATION=true

# =============================================================================
# CELERY CONFIGURATION
# =============================================================================

# Celery Broker
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Worker Settings
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]

# Task Routing
CELERY_TASK_ROUTES={
    "voicehelpdeskai.workers.tasks.process_audio": {"queue": "audio"},
    "voicehelpdeskai.workers.tasks.generate_response": {"queue": "ai"},
    "voicehelpdeskai.workers.tasks.send_notification": {"queue": "notifications"}
}

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Metrics
VOICEHELPDESK_METRICS_ENABLED=true
VOICEHELPDESK_PROMETHEUS_PORT=8001
VOICEHELPDESK_TELEMETRY_ENABLED=true

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-in-production

# Flower (Celery monitoring)
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================

# SSL (if using custom certificates)
NGINX_SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Rate Limiting
NGINX_RATE_LIMIT_API=30r/m
NGINX_RATE_LIMIT_WEBSOCKET=60r/m
NGINX_RATE_LIMIT_UPLOAD=10r/m

# =============================================================================
# BUSINESS LOGIC CONFIGURATION
# =============================================================================

# Conversation Settings
VOICEHELPDESK_MAX_CONVERSATION_LENGTH=30
VOICEHELPDESK_CONVERSATION_TIMEOUT=300
VOICEHELPDESK_AUTO_ESCALATION_ENABLED=true

# Ticket Integration
VOICEHELPDESK_TICKETING_ENABLED=true
VOICEHELPDESK_TICKETING_PROVIDER=mock
VOICEHELPDESK_TICKETING_API_URL=http://localhost:8080
VOICEHELPDESK_TICKETING_API_KEY=your-ticketing-api-key

# User Feedback
VOICEHELPDESK_FEEDBACK_ENABLED=true
VOICEHELPDESK_FEEDBACK_COLLECTION_RATE=0.3

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Audio Features
VOICEHELPDESK_FEATURE_NOISE_REDUCTION=true
VOICEHELPDESK_FEATURE_VOICE_CLONING=false
VOICEHELPDESK_FEATURE_REAL_TIME_STT=true

# AI Features
VOICEHELPDESK_FEATURE_SENTIMENT_ANALYSIS=true
VOICEHELPDESK_FEATURE_INTENT_CLASSIFICATION=true
VOICEHELPDESK_FEATURE_ENTITY_EXTRACTION=true

# Business Features
VOICEHELPDESK_FEATURE_AUTO_SUMMARY=true
VOICEHELPDESK_FEATURE_SMART_ROUTING=true
VOICEHELPDESK_FEATURE_QUALITY_SCORING=true

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================

# Email (for notifications)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=noreply@voicehelpdesk.com
SMTP_PASSWORD=smtp-password
SMTP_TLS=true

# Webhook Notifications
WEBHOOK_URL=https://your-webhook-endpoint.com/notifications
WEBHOOK_SECRET=your-webhook-secret

# Cloud Storage (optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=voicehelpdesk-storage

# =============================================================================
# DEVELOPMENT SETTINGS (ignore in production)
# =============================================================================

# Development Tools
VOICEHELPDESK_RELOAD=false
VOICEHELPDESK_PROFILING=false
VOICEHELPDESK_MOCK_SERVICES=false

# Testing
VOICEHELPDESK_TEST_MODE=false
VOICEHELPDESK_GENERATE_TEST_DATA=false

# =============================================================================
# DOCKER COMPOSE OVERRIDES
# =============================================================================

# Resource Limits
VOICEHELPDESK_MEMORY_LIMIT=2g
VOICEHELPDESK_CPU_LIMIT=2
REDIS_MEMORY_LIMIT=512m

# Volume Mounts
VOICEHELPDESK_DATA_PATH=./data
VOICEHELPDESK_LOGS_PATH=./logs
VOICEHELPDESK_MODELS_PATH=./models

# Network Configuration
VOICEHELPDESK_NETWORK_SUBNET=172.20.0.0/16
MONITORING_NETWORK_SUBNET=172.21.0.0/16