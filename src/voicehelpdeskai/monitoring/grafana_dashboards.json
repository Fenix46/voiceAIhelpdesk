            "gridPos": {"h": 9, "w": 8, "x": 8, "y": 0},
            "targets": [
              {
                "expr": "voicehelpdesk_redis_memory_usage_bytes / 1024 / 1024",
                "refId": "A",
                "legendFormat": "Memory Usage (MB)"
              }
            ]
          },
          {
            "id": 3,
            "title": "Queue Depths",
            "type": "graph",
            "gridPos": {"h": 9, "w": 8, "x": 16, "y": 0},
            "targets": [
              {
                "expr": "voicehelpdesk_queue_depth",
                "refId": "A",
                "legendFormat": "{{queue_name}}"
              }
            ]
          },
          {
            "id": 4,
            "title": "Task Processing Time",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_task_duration_seconds_bucket[5m])) by (le, task_type))",
                "refId": "A",
                "legendFormat": "{{task_type}} - 95th"
              }
            ],
            "yAxes": [
              {
                "unit": "s"
              }
            ]
          },
          {
            "id": 5,
            "title": "Task Failures",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_task_failures_total[5m])) by (task_type, error_type)",
                "refId": "A",
                "legendFormat": "{{task_type}} - {{error_type}}"
              }
            ]
          },
          {
            "id": 6,
            "title": "Worker Utilization",
            "type": "graph",
            "gridPos": {"h": 9, "w": 8, "x": 0, "y": 18},
            "targets": [
              {
                "expr": "voicehelpdesk_worker_utilization_ratio",
                "refId": "A",
                "legendFormat": "{{worker_type}}"
              }
            ],
            "yAxes": [
              {
                "unit": "percentunit",
                "min": 0,
                "max": 1
              }
            ]
          },
          {
            "id": 7,
            "title": "System Memory",
            "type": "graph",
            "gridPos": {"h": 9, "w": 8, "x": 8, "y": 18},
            "targets": [
              {
                "expr": "voicehelpdesk_memory_usage_bytes{memory_type=\"used\"} / voicehelpdesk_memory_usage_bytes{memory_type=\"total\"}",
                "refId": "A",
                "legendFormat": "Memory Usage %"
              }
            ],
            "yAxes": [
              {
                "unit": "percentunit",
                "min": 0,
                "max": 1
              }
            ]
          },
          {
            "id": 8,
            "title": "CPU Usage",
            "type": "graph",
            "gridPos": {"h": 9, "w": 8, "x": 16, "y": 18},
            "targets": [
              {
                "expr": "voicehelpdesk_cpu_usage_percent",
                "refId": "A",
                "legendFormat": "CPU Usage %"
              }
            ],
            "yAxes": [
              {
                "unit": "percent",
                "min": 0,
                "max": 100
              }
            ]
          }
        ]
      }
    },
    {
      "dashboard": {
