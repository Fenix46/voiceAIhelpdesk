{
  "dashboards": [
    {
      "dashboard": {
        "id": null,
        "uid": "voicehelpdesk-overview",
        "title": "VoiceHelpDeskAI - System Overview",
        "description": "High-level overview of VoiceHelpDeskAI system health and performance",
        "tags": ["voicehelpdesk", "overview", "monitoring"],
        "timezone": "browser",
        "refresh": "30s",
        "schemaVersion": 27,
        "version": 1,
        "time": {
          "from": "now-1h",
          "to": "now"
        },
        "timepicker": {
          "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
        },
        "panels": [
          {
            "id": 1,
            "title": "System Health",
            "type": "stat",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
            "targets": [
              {
                "expr": "voicehelpdesk_app_info",
                "refId": "A"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "color": {"mode": "thresholds"},
                "thresholds": {
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "red", "value": 0}
                  ]
                }
              }
            }
          },
          {
            "id": 2,
            "title": "Active Conversations",
            "type": "stat",
            "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
            "targets": [
              {
                "expr": "sum(voicehelpdesk_websocket_connections_active)",
                "refId": "A"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "color": {"mode": "palette-classic"}
              }
            }
          },
          {
            "id": 3,
            "title": "Request Rate",
            "type": "stat",
            "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_http_requests_total[5m]))",
                "refId": "A"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "unit": "reqps"
              }
            }
          },
          {
            "id": 4,
            "title": "Response Time (95th percentile)",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 8},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_http_request_duration_seconds_bucket[5m])) by (le))",
                "refId": "A",
                "legendFormat": "95th percentile"
              }
            ],
            "yAxes": [
              {
                "unit": "s",
                "min": 0
              }
            ]
          },
          {
            "id": 5,
            "title": "Error Rate",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 8},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(voicehelpdesk_http_requests_total[5m]))",
                "refId": "A",
                "legendFormat": "Error Rate"
              }
            ],
            "yAxes": [
              {
                "unit": "percentunit",
                "min": 0,
                "max": 1
              }
            ]
          },
          {
            "id": 6,
            "title": "Memory Usage",
            "type": "graph",
            "gridPos": {"h": 9, "w": 8, "x": 0, "y": 17},
            "targets": [
              {
                "expr": "voicehelpdesk_memory_usage_bytes{memory_type=\"rss\"} / 1024 / 1024",
                "refId": "A",
                "legendFormat": "RSS Memory (MB)"
              }
            ]
          },
          {
            "id": 7,
            "title": "CPU Usage",
            "type": "graph",
            "gridPos": {"h": 9, "w": 8, "x": 8, "y": 17},
            "targets": [
              {
                "expr": "voicehelpdesk_cpu_usage_percent",
                "refId": "A",
                "legendFormat": "CPU Usage %"
              }
            ],
            "yAxes": [
              {
                "unit": "percent",
                "min": 0,
                "max": 100
              }
            ]
          },
          {
            "id": 8,
            "title": "Queue Depths",
            "type": "graph",
            "gridPos": {"h": 9, "w": 8, "x": 16, "y": 17},
            "targets": [
              {
                "expr": "voicehelpdesk_queue_depth",
                "refId": "A",
                "legendFormat": "{{queue_name}}"
              }
            ]
          }
        ]
      }
    },
    {
      "dashboard": {
        "id": null,
        "uid": "voicehelpdesk-api",
        "title": "VoiceHelpDeskAI - API Performance",
        "description": "Detailed API performance metrics and analysis",
        "tags": ["voicehelpdesk", "api", "performance"],
        "timezone": "browser",
        "refresh": "30s",
        "schemaVersion": 27,
        "version": 1,
        "time": {
          "from": "now-1h",
          "to": "now"
        },
        "panels": [
          {
            "id": 1,
            "title": "Request Rate by Endpoint",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_http_requests_total[5m])) by (endpoint)",
                "refId": "A",
                "legendFormat": "{{endpoint}}"
              }
            ],
            "yAxes": [
              {
                "unit": "reqps"
              }
            ]
          },
          {
            "id": 2,
            "title": "Response Time by Endpoint",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
                "refId": "A",
                "legendFormat": "{{endpoint}} - 95th"
              },
              {
                "expr": "histogram_quantile(0.50, sum(rate(voicehelpdesk_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
                "refId": "B",
                "legendFormat": "{{endpoint}} - 50th"
              }
            ],
            "yAxes": [
              {
                "unit": "s"
              }
            ]
          },
          {
            "id": 3,
            "title": "HTTP Status Codes",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_http_requests_total[5m])) by (status)",
                "refId": "A",
                "legendFormat": "{{status}}"
              }
            ],
            "yAxes": [
              {
                "unit": "reqps"
              }
            ]
          },
          {
            "id": 4,
            "title": "Request/Response Size",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_request_size_bytes_bucket[5m])) by (le))",
                "refId": "A",
                "legendFormat": "Request Size - 95th"
              },
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_response_size_bytes_bucket[5m])) by (le))",
                "refId": "B",
                "legendFormat": "Response Size - 95th"
              }
            ],
            "yAxes": [
              {
                "unit": "bytes"
              }
            ]
          },
          {
            "id": 5,
            "title": "WebSocket Connections",
            "type": "graph",
            "gridPos": {"h": 9, "w": 24, "x": 0, "y": 18},
            "targets": [
              {
                "expr": "voicehelpdesk_websocket_connections_active",
                "refId": "A",
                "legendFormat": "{{endpoint}}"
              }
            ]
          }
        ]
      }
    },
    {
      "dashboard": {
        "id": null,
        "uid": "voicehelpdesk-ai",
        "title": "VoiceHelpDeskAI - AI Models",
        "description": "AI model performance, inference times, and accuracy metrics",
        "tags": ["voicehelpdesk", "ai", "models"],
        "timezone": "browser",
        "refresh": "30s",
        "schemaVersion": 27,
        "version": 1,
        "time": {
          "from": "now-1h",
          "to": "now"
        },
        "panels": [
          {
            "id": 1,
            "title": "Model Inference Time",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_model_inference_duration_seconds_bucket[5m])) by (le, model_type))",
                "refId": "A",
                "legendFormat": "{{model_type}} - 95th"
              },
              {
                "expr": "histogram_quantile(0.50, sum(rate(voicehelpdesk_model_inference_duration_seconds_bucket[5m])) by (le, model_type))",
                "refId": "B",
                "legendFormat": "{{model_type}} - 50th"
              }
            ],
            "yAxes": [
              {
                "unit": "s"
              }
            ]
          },
          {
            "id": 2,
            "title": "Model Confidence Scores",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_model_confidence_score_bucket[5m])) by (le, model_type))",
                "refId": "A",
                "legendFormat": "{{model_type}} - 95th"
              }
            ],
            "yAxes": [
              {
                "unit": "short",
                "min": 0,
                "max": 1
              }
            ]
          },
          {
            "id": 3,
            "title": "Model Failures",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_model_failures_total[5m])) by (model_type, error_type)",
                "refId": "A",
                "legendFormat": "{{model_type}} - {{error_type}}"
              }
            ],
            "yAxes": [
              {
                "unit": "ops"
              }
            ]
          },
          {
            "id": 4,
            "title": "Token Usage (LLM)",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_llm_tokens_total[5m])) by (token_type)",
                "refId": "A",
                "legendFormat": "{{token_type}}"
              }
            ],
            "yAxes": [
              {
                "unit": "tps"
              }
            ]
          },
          {
            "id": 5,
            "title": "Model Memory Usage",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 18},
            "targets": [
              {
                "expr": "voicehelpdesk_model_memory_usage_bytes / 1024 / 1024",
                "refId": "A",
                "legendFormat": "{{model_type}}/{{model_name}} (MB)"
              }
            ]
          },
          {
            "id": 6,
            "title": "STT Accuracy",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 18},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_stt_accuracy_score_bucket[5m])) by (le, language))",
                "refId": "A",
                "legendFormat": "{{language}} - 95th"
              }
            ],
            "yAxes": [
              {
                "unit": "short",
                "min": 0,
                "max": 1
              }
            ]
          }
        ]
      }
    },
    {
      "dashboard": {
        "id": null,
        "uid": "voicehelpdesk-business",
        "title": "VoiceHelpDeskAI - Business Metrics",
        "description": "Business KPIs, user satisfaction, and conversation analytics",
        "tags": ["voicehelpdesk", "business", "kpi"],
        "timezone": "browser",
        "refresh": "1m",
        "schemaVersion": 27,
        "version": 1,
        "time": {
          "from": "now-24h",
          "to": "now"
        },
        "panels": [
          {
            "id": 1,
            "title": "Conversations Started",
            "type": "stat",
            "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
            "targets": [
              {
                "expr": "sum(increase(voicehelpdesk_conversations_started_total[24h]))",
                "refId": "A"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "color": {"mode": "palette-classic"}
              }
            }
          },
          {
            "id": 2,
            "title": "Conversations Completed",
            "type": "stat",
            "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
            "targets": [
              {
                "expr": "sum(increase(voicehelpdesk_conversations_completed_total[24h]))",
                "refId": "A"
              }
            ]
          },
          {
            "id": 3,
            "title": "Success Rate",
            "type": "stat",
            "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
            "targets": [
              {
                "expr": "sum(increase(voicehelpdesk_conversations_completed_total[24h])) / sum(increase(voicehelpdesk_conversations_started_total[24h]))",
                "refId": "A"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "unit": "percentunit",
                "thresholds": {
                  "steps": [
                    {"color": "red", "value": 0},
                    {"color": "yellow", "value": 0.7},
                    {"color": "green", "value": 0.85}
                  ]
                }
              }
            }
          },
          {
            "id": 4,
            "title": "Avg Satisfaction Score",
            "type": "stat",
            "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
            "targets": [
              {
                "expr": "histogram_quantile(0.50, sum(rate(voicehelpdesk_user_satisfaction_score_bucket[24h])) by (le))",
                "refId": "A"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "min": 1,
                "max": 5,
                "thresholds": {
                  "steps": [
                    {"color": "red", "value": 1},
                    {"color": "yellow", "value": 3},
                    {"color": "green", "value": 4}
                  ]
                }
              }
            }
          },
          {
            "id": 5,
            "title": "Conversation Duration",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 8},
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum(rate(voicehelpdesk_conversation_duration_seconds_bucket[5m])) by (le, channel))",
                "refId": "A",
                "legendFormat": "{{channel}} - 95th"
              },
              {
                "expr": "histogram_quantile(0.50, sum(rate(voicehelpdesk_conversation_duration_seconds_bucket[5m])) by (le, channel))",
                "refId": "B",
                "legendFormat": "{{channel}} - 50th"
              }
            ],
            "yAxes": [
              {
                "unit": "s"
              }
            ]
          },
          {
            "id": 6,
            "title": "User Satisfaction Trend",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 8},
            "targets": [
              {
                "expr": "histogram_quantile(0.50, sum(rate(voicehelpdesk_user_satisfaction_score_bucket[1h])) by (le))",
                "refId": "A",
                "legendFormat": "Average Satisfaction"
              }
            ],
            "yAxes": [
              {
                "unit": "short",
                "min": 1,
                "max": 5
              }
            ]
          },
          {
            "id": 7,
            "title": "Tickets Created",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 0, "y": 17},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_tickets_created_total[5m])) by (category)",
                "refId": "A",
                "legendFormat": "{{category}}"
              }
            ]
          },
          {
            "id": 8,
            "title": "Escalations",
            "type": "graph",
            "gridPos": {"h": 9, "w": 12, "x": 12, "y": 17},
            "targets": [
              {
                "expr": "sum(rate(voicehelpdesk_escalations_total[5m])) by (reason)",
                "refId": "A",
                "legendFormat": "{{reason}}"
              }
            ]
          }
        ]
      }
    },
    {
      "dashboard": {
        "id": null,
        "uid": "voicehelpdesk-infrastructure",
        "title": "VoiceHelpDeskAI - Infrastructure",
        "description": "Infrastructure monitoring: Redis, queues, workers, and resources",
        "tags": ["voicehelpdesk", "infrastructure", "resources"],
