              "raw": "{\n  \"title\": \"Disconnessioni frequenti dalla rete Wi-Fi\",\n  \"description\": \"Da questa mattina il mio laptop si disconnette dalla rete Wi-Fi ogni 10-15 minuti. Devo riconnettermi manualmente ogni volta. Questo compromette il mio lavoro da remoto e le videochiamate con i clienti.\",\n  \"priority\": 4,\n  \"category\": \"network\",\n  \"subcategory\": \"wifi\",\n  \"user_id\": \"{{userId}}\",\n  \"reporter_email\": \"andrea.verdi@company.com\",\n  \"affected_systems\": [\"Wi-Fi\", \"Laptop Lenovo\"],\n  \"tags\": [\"wifi\", \"disconnessioni\", \"rete\", \"remoto\"],\n  \"business_impact\": \"Interruzioni continue durante meeting clienti\",\n  \"urgency_justification\": \"Meeting importanti programmati oggi pomeriggio\"\n}"
