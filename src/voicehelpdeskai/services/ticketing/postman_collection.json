            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Excel si blocca quando apro file grandi\",\n  \"description\": \"Stavo lavorando su un file Excel di 50MB quando improvvisamente l'applicazione si è chiusa senza salvare il mio lavoro. Questo succede ogni volta che provo ad aprire file superiori a 30MB. Ho perso 3 ore di lavoro e devo consegnare il report domani mattina.\",\n  \"priority\": 4,\n  \"category\": \"software\",\n  \"subcategory\": \"office\",\n  \"user_id\": \"{{userId}}\",\n  \"reporter_email\": \"mario.rossi@company.com\",\n  \"reporter_phone\": \"+39 123 456 7890\",\n  \"affected_systems\": [\"Microsoft Excel\", \"Windows 10\"],\n  \"asset_ids\": [\"PC-001\", \"LIC-OFF365-001\"],\n  \"tags\": [\"excel\", \"crash\", \"file-grandi\", \"urgente\"],\n  \"business_impact\": \"Blocco attività di reporting finanziario\",\n  \"urgency_justification\": \"Scadenza report per il management domani\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"]
            }
          }
        },
